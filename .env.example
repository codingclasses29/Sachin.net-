# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email notifications
NODEMAILER_EMAIL=your@gmail.com
NODEMAILER_PASSWORD=your-16-char-app-password
CONTACT_ALERT_EMAIL=your@gmail.com
SCHOOL_NAME=Sachin.net

# Twilio SMS / WhatsApp alerts
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
ADMIN_ALERT_PHONE_NUMBER=

# AI — Groq (fast Llama/Mixtral)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# AI — Google Gemini (primary)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# AI — OpenRouter (multi-model gateway)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# AI — OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Active AI provider: gemini | groq | openrouter | openai
AI_PROVIDER=gemini
AI_API_KEY=
AI_MODEL=gemini-2.0-flash
AI_MAX_TOKENS=1024
AI_TEMPERATURE=0.7
AI_PROVIDER_ORDER=groq,openrouter,openai,ollama
NEXT_PUBLIC_AI_PROVIDER=gemini

# Ollama fallback (local only)
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=
OLLAMA_MODEL=llama3
